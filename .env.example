# Default deployment behavior:
# Keep model-backed Forge routes disabled unless explicitly enabled.
FORGE_MODEL_API_ENABLED=0

# Gemini generation:
# Set both values below, then open /forge?gemini=1.
# GOOGLE_API_KEY=
# FORGE_MODEL_API_ENABLED=1

# Optional: default reviewed image generation is off unless explicitly enabled.
FORGE_REVIEWED_ART_DEFAULT=false

# Optional: standalone hosted deploy smoke tests require Vercel credentials.
# VERCEL_TOKEN=
# VERCEL_TEAM_ID=

# Reserved for alternate model-provider experiments.
# OPENROUTER_API_KEY=
