# Public demo deployment:
# Keep model APIs disabled so shared demo traffic does not spend tokens.
FORGE_MODEL_API_ENABLED=0

# Local/private Gemini generation:
# Set both values below, then open /forge?gemini=1.
# GOOGLE_API_KEY=your_google_ai_studio_key
# FORGE_MODEL_API_ENABLED=1

# Optional: default reviewed image generation is off unless explicitly enabled.
FORGE_REVIEWED_ART_DEFAULT=false

# Optional: standalone hosted deploy smoke tests require Vercel credentials.
# VERCEL_TOKEN=your_vercel_token
# VERCEL_TEAM_ID=your_vercel_team_id

# Reserved for experiments; the current Forge model path uses Gemini via GOOGLE_API_KEY.
# OPENROUTER_API_KEY=your_openrouter_key
