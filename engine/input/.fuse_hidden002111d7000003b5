/**
 * Input layer backing each generated game's systems/controller — keyboard, touch, and gamepad
 * mapped to a typed action set the game's systems query each tick.
 */
import { z } from 'zod';

const INPUT_LOG_PREFIX = '[engine/input/controller]';

/**
 * Binding spec for a single action. `keyboard` holds `KeyboardEvent.code` values (e.g. 'KeyW',
 * 'ArrowUp', 'Space'); `gamepadButtons` are standard-gamepad button indices; `touchZones` are
 * named on-screen control ids the touch layer reports. All optional so an action can be bound to
 * any subset of devices. a11y: bindings are fully configurable so games can offer remapping.
 */
export const ActionBindingSchema = z.object({
  keyboard: z.array(z.string().min(1)).optional(),
  gamepadButtons: z.array(z.number().int().nonnegative()).optional(),
  touchZones: z.array(z.string().min(1)).optional(),
});
export type ActionBinding = z.infer<typeof ActionBindingSchema>;

/** A binding map keyed by action name. The action names become the game's typed action set. */
export const ActionMapSchema = z.record(z.string().min(1), ActionBindingSchema);
export type ActionMap = z.infer<typeof ActionMapSchema>;

/** Per-action runtime state queried by systems each tick. */
export interface ActionState {
  /** Held this tick. */
  active: boolean;
  /** Became active since the previous `endFrame()` (rising edge). */
  pressed: boolean;
  /** Became inactive since the previous `endFrame()` (falling edge). */
  released: boolean;
  /** Analog magnitude 0..1 (1 for digital sources; gamepad axes/triggers report partial). */
  value: number;
}

function emptyState(): ActionState {
  return { active: false, pressed: false, released: false, value: 0 };
}

/**
 * Structural slice of an EventTarget (window/document/element) the keyboard+touch layers attach
 * to. Tests inject a fake; the module never references a global `window`/`document`.
 */
export interface EventSourceLike {
  addEventListener(type: string, listener: (event: unknown) => void): void;
  removeEventListener(type: string, listener: (event: unknown) => void): void;
}

/** Structural slice of the Gamepad API navigator the poll loop reads. */
export interface GamepadProviderLike {
  getGamepads(): ReadonlyArray<GamepadLike | null>;
}

export interface GamepadLike {
  readonly buttons: ReadonlyArray<{ readonly pressed: boolean; readonly value: number }>;
  readonly axes: ReadonlyArray<number>;
}

export interface ControllerOptions {
  /** Action → device bindings. Validated with Zod. */
  bindings: ActionMap;
  /** Keyboard/touch event source (e.g. `window`). Omit for headless/playtester use. */
  keyboardSource?: EventSourceLike;
  /** Touch event source (defaults to `keyboardSource` if given). */
  touchSource?: EventSourceLike;
  /** Gamepad provider (e.g. `navigator`). Omit to disable gamepad polling. */
  gamepadProvider?: GamepadProviderLike;
  /** Axis magnitude below this counts as zero (stick drift guard). Default 0.15. */
  gamepadDeadzone?: number;
}

interface KeyboardTouchEvent {
  code?: string;
  zone?: string;
  preventDefault?: () => void;
}

/**
 * Typed input controller. Construct via {@link createController}, attach device listeners with
 * {@link Controller.attach}, then each game tick call {@link Controller.poll} (gamepad sampling)
 * → query actions via {@link Controller.isActive} / {@link Controller.getAction} → finish the
 * tick with {@link Controller.endFrame} to clear rising/falling edges.
 *
 * The playtester drives the same action set headlessly through {@link Controller.inject} /
 * {@link Controller.injectAxis} without any DOM.
 */
export class Controller {
  private readonly bindings: ActionMap;
  private readonly actions = new Map<string, ActionState>();
  /** Digital sources currently down, keyed by `source:id` so multiple devices coexist. */
  private readonly downSources = new Map<string, Set<string>>();
  /** Analog overrides per action (highest magnitude wins for the tick). */
  private readonly analogValues = new Map<string, number>();
  /** Programmatic (playtester) digital injections, persisted until released. */
  private readonly injectedDown = new Set<string>();
  /** One-shot injected taps consumed by the next single poll (then auto-released). */
  private readonly tappedOnce = new Set<string>();

  private readonly keyboardSource: EventSourceLike | undefined;
  private readonly touchSource: EventSourceLike | undefined;
  private readonly gamepadProvider: GamepadProviderLike | undefined;
  private readonly deadzone: number;

  private readonly keyToActions = new Map<string, string[]>();
  private readonly zoneToActions = new Map<string, string[]>();
  private readonly buttonToActions = new Map<number, string[]>();

  private attached = false;
  private readonly listeners: Array<{ src: EventSourceLike; type: string; fn: (e: unknown) => void }> = [];

  constructor(opts: ControllerOptions) {
    if (!opts || !opts.bindings) {
      throw new Error(`${INPUT_LOG_PREFIX} createController requires a bindings map`);
    }
    const parsed = ActionMapSchema.safeParse(opts.bindings);
    if (!parsed.success) {
      console.error(`${INPUT_LOG_PREFIX} invalid bindings ${parsed.error.message}`);
      throw new Error(`${INPUT_LOG_PREFIX} bindings failed validation`);
    }
    this.bindings = parsed.data;
    this.keyboardSource = opts.keyboardSource;
    this.touchSource = opts.touchSource ?? opts.keyboardSource;
    this.gamepadProvider = opts.gamepadProvider;
    this.deadzone = opts.gamepadDeadzone ?? 0.15;

    for (const [action, binding] of Object.entries(this.bindings)) {
      this.actions.set(action, emptyState());
      for (const code of binding.keyboard ?? []) {
        this.keyToActions.set(code, [...(this.keyToActions.get(code) ?? []), action]);
      }
      for (const zone of binding.touchZones ?? []) {
        this.zoneToActions.set(zone, [...(this.zoneToActions.get(zone) ?? []), action]);
      }
      for (const btn of binding.gamepadButtons ?? []) {
        this.buttonToActions.set(btn, [...(this.buttonToActions.get(btn) ?? []), action]);
      }
    }

    console.log(
      `${INPUT_LOG_PREFIX} init actions=${this.actions.size} keyboard=${Boolean(this.keyboardSource)} gamepad=${Boolean(this.gamepadProvider)} deadzone=${this.deadzone}`,
    );
  }

  /** The set of action names this controller understands. */
  actionNames(): string[] {
    return Array.from(this.actions.keys());
  }

  /** Attach keyboard/touch DOM listeners (no-op if no source / already attached). */
  attach(): void {
    if (this.attached) {
      console.log(`${INPUT_LOG_PREFIX} attach skipped — already attached`);
      return;
    }
    const bind = (src: EventSourceLike | undefined, type: string, fn: (e: unknown) => void): void => {
      if (!src) return;
      src.addEventListener(type, fn);
      this.listeners.push({ src, type, fn });
    };

    bind(this.keyboardSource, 'keydown', (e) => this.handleKey(e as KeyboardTouchEvent, true));
    bind(this.keyboardSource, 'keyup', (e) => this.handleKey(e as KeyboardTouchEvent, false));
    bind(this.touchSource, 'touchzonedown', (e) => this.handleZone(e as KeyboardTouchEvent, true));
    bind(this.touchSource, 'touchzoneup', (e) => this.handleZone(e as KeyboardTouchEvent, false));

    this.attached = true;
    console.log(`${INPUT_LOG_PREFIX} attached listeners=${this.listeners.length}`);
  }

  /** Detach all DOM listeners and clear transient state. */
  detach(): void {
    for (const { src, type, fn } of this.listeners) {
      try {
        src.removeEventListener(type, fn);
      } catch (err) {
        console.error(`${INPUT_LOG_PREFIX} removeEventListener err type=${type} err=${String(err)}`);
      }
    }
    this.listeners.length = 0;
    this.attached = false;
    console.log(`${INPUT_LOG_PREFIX} detached`);
  }

  private setDown(source: string, id: string, down: boolean): void {
    let set = this.downSources.get(source);
    if (!set) {
      set = new Set<string>();
      this.downSources.set(source, set);
    }
    if (down) set.add(id);
    else set.delete(id);
  }

  private handleKey(event: KeyboardTouchEvent, down: boolean): void {
    const code = event?.code;
    if (!code) return;
    if (!this.keyToActions.has(code)) return;
    this.setDown('keyboard', code, down);
    console.log(`${INPUT_LOG_PREFIX} key ${down ? 'down' : 'up'} code=${code}`);
  }

  private handleZone(event: KeyboardTouchEvent, down: boolean): void {
    const zone = event?.zone;
    if (!zone) return;
    if (!this.zoneToActions.has(zone)) return;
    this.setDown('touch', zone, down);
    console.log(`${INPUT_LOG_PREFIX} touch ${down ? 'down' : 'up'} zone=${zone}`);
  }

  /**
   * Programmatic injection path for the playtester / headless drivers. Sets a digital action
   * down (held until injected up). Validates the action exists.
   */
  inject(action: string, down: boolean): void {
    if (!this.actions.has(action)) {
      console.error(`${INPUT_LOG_PREFIX} inject unknown action=${action} known=${this.actionNames().join(',')}`);
      throw new Error(`${INPUT_LOG_PREFIX} inject: no such action=${action}`);
    }
    if (down) this.injectedDown.add(action);
    else this.injectedDown.delete(action);
    console.log(`${INPUT_LOG_PREFIX} inject action=${action} down=${down}`);
  }

  /** Inject an analog magnitude (0..1) for an action this tick (cleared each poll). */
  injectAxis(action: string, value: number): void {
    if (!this.actions.has(action)) {
      console.error(`${INPUT_LOG_PREFIX} injectAxis unknown action=${action}`);
      throw new Error(`${INPUT_LOG_PREFIX} injectAxis: no such action=${action}`);
    }
    const v = value < 0 ? 0 : value > 1 ? 1 : Number.isNaN(value) ? 0 : value;
    const prev = this.analogValues.get(action) ?? 0;
    if (v > prev) this.analogValues.set(action, v);
    console.log(`${INPUT_LOG_PREFIX} injectAxis action=${action} value=${v}`);
  }

  /**
   * Tap = a one-shot press registered on the NEXT `poll` only, then auto-released (so the
   * playtester gets a clean pressed→released edge over one tick without manual down/up bracketing).
   */
  tap(action: string): void {
    if (!this.actions.has(action)) {
      console.error(`${INPUT_LOG_PREFIX} tap unknown action=${action}`);
      throw new Error(`${INPUT_LOG_PREFIX} tap: no such action=${action}`);
    }
    this.tappedOnce.add(action);
    console.log(`${INPUT_LOG_PREFIX} tap action=${action}`);
  }

  private sampleGamepads(): void {
    if (!this.gamepadProvider) return;
    const pads = this.gamepadProvider.getGamepads();
    if (!Array.isArray(pads) && typeof pads?.[Symbol.iterator] !== 'function') return;
    let padIndex = 0;
    for (const pad of pads) {
      if (!pad) {
        padIndex++;
        continue;
      }
      for (const [btnIndex, actionsForBtn] of this.buttonToActions.entries()) {
        const btn = pad.buttons[btnIndex];
        const pressed = Boolean(btn?.pressed) || (btn?.value ?? 0) > this.deadzone;
        this.setDown(`gamepad${padIndex}`, `b${btnIndex}`, pressed);
        if (btn && btn.value > this.deadzone) {
          for (const action of actionsForBtn) {
            const prev = this.analogValues.get(action) ?? 0;
            if (btn.value > prev) this.analogValues.set(action, Math.min(1, btn.value));
          }
        }
      }
      padIndex++;
    }
  }

  /**
   * Compute this-tick action states. Aggregates keyboard/touch/gamepad/injected digital
   * sources + analog values, derives pressed/released edges vs the previous frame. Call once per
   * tick BEFORE querying. Gamepad analog injections are transient and cleared here.
   */
  poll(): void {
    this.analogValues.clear();
    this.sampleGamepads();

    for (const [action, state] of this.actions.entries()) {
      const digitalDown = this.isDigitalDown(action);
      const analog = this.analogValues.get(action) ?? 0;
      const active = digitalDown || analog > 0;
      const value = active ? Math.max(analog, digitalDown ? 1 : 0) : 0;

      const wasActive = state.active;
      state.pressed = active && !wasActive;
      state.released = !active && wasActive;
      state.active = active;
      state.value = value;
    }
    // One-shot taps are consumed by this single poll; release for the next tick.
    this.tappedOnce.clear();
  }

  private isDigitalDown(action: string): boolean {
    if (this.injectedDown.has(action)) return true;
    if (this.tappedOnce.has(action)) return true;
    const binding = this.bindings[action];
    if (!binding) return false;
    for (const code of binding.keyboard ?? []) {
      if (this.downSources.get('keyboard')?.has(code)) return true;
    }
    for (const zone of binding.touchZones ?? []) {
      if (this.downSources.get('touch')?.has(zone)) return true;
    }
    for (const [source, ids] of this.downSources.entries()) {
      if (!source.startsWith('gamepad')) continue;
      for (const btn of binding.gamepadButtons ?? []) {
        if (ids.has(`b${btn}`)) return true;
      }
    }
    return false;
  }

  /** Full action state for this tick. Unknown actions return a neutral state. */
  getAction(action: string): ActionState {
    const state = this.actions.get(action);
    if (!state) {
      console.error(`${INPUT_LOG_PREFIX} getAction unknown action=${action}`);
      return emptyState();
    }
    return { ...state };
  }

  /** Held this tick. */
  isActive(action: string): boolean {
    return this.actions.get(action)?.active ?? false;
  }

  /** Rising edge this tick. */
  isPressed(action: string): boolean {
    return this.actions.get(action)?.pressed ?? false;
  }

  /** Falling edge this tick. */
  isReleased(action: string): boolean {
    return this.actions.get(action)?.released ?? false;
  }

  /** Analog magnitude this tick (0..1). */
  getValue(action: string): number {
    return this.actions.get(action)?.value ?? 0;
  }

  /** Snapshot of every action's state (for the playtester's invariant assertions). */
  snapshot(): Record<string, ActionState> {
    const out: Record<string, ActionState> = {};
    for (const [action, state] of this.actions.entries()) {
      out[action] = { ...state };
    }
    return out;
  }

  /**
   * Clear rising/falling edges so the next `poll` recomputes them fresh. Call at the END of
   * each tick. Held (active) state persists; tap-style injected releases are already applied.
   */
  endFrame(): void {
    for (const state of this.actions.values()) {
      state.pressed = false;
      state.released = false;
    }
  }

  /** Reset all input state (held keys, injections, edges) without detaching listeners. */
  reset(): void {
    this.downSources.clear();
    this.analogValues.clear();
    this.injectedDown.clear();
    this.tappedOnce.clear();
    for (const [action] of this.actions) {
      this.actions.set(action, emptyState());
    }
    console.log(`${INPUT_LOG_PREFIX} reset`);
  }
}

/** Factory mirroring the engine's provider-style API. */
export function createController(opts: ControllerOptions): Controller {
  return new Controller(opts);
}
